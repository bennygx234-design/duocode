# ── Anthropic ──────────────────────────────────────────────────────────────────
# Obtain from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub OAuth App ───────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
#   Homepage URL:         http://localhost:5173
#   Authorization callback URL: http://localhost:3001/auth/github/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ── GitHub Webhook ─────────────────────────────────────────────────────────────
# Used to verify incoming webhook payloads from GitHub.
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_webhook_secret_32_chars_or_more

# ── Express Session ────────────────────────────────────────────────────────────
# Must be at least 32 random characters.
# Generate with: openssl rand -hex 32
SESSION_SECRET=a_random_secret_string_at_least_32_chars

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001

# ── Database ───────────────────────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file.
DATABASE_PATH=./server/duocode.db

# ── Client origin (CORS) ──────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
